# Skopíruj tento súbor na ".env" a vyplň reálnymi hodnotami.
# .env je v .gitignore, takže sa nikdy nedostane do gitu.

# --- Claude API ---
# Získaš na https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Ktorý model agent používa. Na chat staèí lacný/rýchly.
# Možnosti: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8
AGENT_MODEL=claude-sonnet-4-6

# --- Meta WhatsApp Cloud API ---
# Z Meta for Developers → tvoja App → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Ľubovoľný tajný reťazec, ktorý si vymyslíš. Použiješ ho pri
# nastavovaní webhooku v Meta (musí sa zhodovať na oboch stranách).
WHATSAPP_VERIFY_TOKEN=moj-tajny-verify-token-12345
