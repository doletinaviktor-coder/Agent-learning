# Skopíruj tento súbor na ".env" a vyplň reálnymi hodnotami.
# .env je v .gitignore, takže sa nikdy nedostane do gitu.

# --- Claude API ---
# Získaš na https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Ktorý model agent používa. Na chat staèí lacný/rýchly.
# Možnosti: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8
AGENT_MODEL=claude-sonnet-4-6

# --- Meta WhatsApp Cloud API ---
# Z Meta for Developers → tvoja App → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Ľubovoľný tajný reťazec, ktorý si vymyslíš. Použiješ ho pri
# nastavovaní webhooku v Meta (musí sa zhodovať na oboch stranách).
WHATSAPP_VERIFY_TOKEN=moj-tajny-verify-token-12345

# --- Slack (Socket Mode) ---
# Z api.slack.com/apps → tvoja App
# Bot token: OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# App-level token: Basic Information → App-Level Tokens, scope connections:write (xapp-...)
SLACK_APP_TOKEN=xapp-...

# --- Google Analytics 4 ---
# Číselné ID property: GA4 → Admin → Property Settings → Property ID
GA4_PROPERTY_ID=123456789
# Cesta k JSON kľúču service accountu (stiahnutý z Google Cloud).
# Tip: ulož ho do priečinka projektu ako ga4-key.json (je v .gitignore).
GOOGLE_APPLICATION_CREDENTIALS=./ga4-key.json
